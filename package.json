{
  "name": "@open-resource-discovery/a2a-editor",
  "version": "0.4.4",
  "description": "Analyze, validate, and interact with Agent-to-Agent (A2A) protocol agent cards. Connect to agents, inspect their capabilities, and test communication in real-time.",
  "license": "Apache-2.0",
  "author": "SAP SE",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist-standalone/a2a-playground.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-resource-discovery/a2a-editor.git"
  },
  "homepage": "https://github.com/open-resource-discovery/a2a-editor#readme",
  "bugs": {
    "url": "https://github.com/open-resource-discovery/a2a-editor/issues"
  },
  "keywords": [
    "a2a",
    "agent-to-agent",
    "agent-card",
    "editor",
    "react",
    "viewer"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./lite": {
      "import": "./dist/playground-lite.js",
      "types": "./dist/playground-lite.d.ts"
    },
    "./viewer": {
      "import": "./dist/viewer.js",
      "types": "./dist/viewer.d.ts"
    },
    "./editor": {
      "import": "./dist/editor.js",
      "types": "./dist/editor.d.ts"
    },
    "./card-view": {
      "import": "./dist/card-view.js",
      "types": "./dist/card-view.d.ts"
    },
    "./styles": "./dist/index.css",
    "./standalone": "./dist-standalone/a2a-playground.js",
    "./standalone/css": "./dist-standalone/a2a-playground.css"
  },
  "files": [
    "dist/index.js",
    "dist/index.css",
    "dist/index.d.ts",
    "dist/playground-lite.js",
    "dist/playground-lite.d.ts",
    "dist/viewer.js",
    "dist/viewer.d.ts",
    "dist/editor.js",
    "dist/editor.d.ts",
    "dist/card-view.js",
    "dist/card-view.d.ts",
    "dist/chunks",
    "dist/components/**/*.d.ts",
    "dist/hooks/**/*.d.ts",
    "dist/stores/**/*.d.ts",
    "dist/types/**/*.d.ts",
    "dist/utils/**/*.d.ts",
    "dist/mock/**/*.d.ts",
    "dist-standalone/a2a-playground.js",
    "dist-standalone/a2a-playground.css",
    "dist-standalone/a2a-initializer.js",
    "dist-standalone/index.html",
    "dist-standalone/standalone.html",
    "dist-standalone/index.cjs",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "prepack": "npm run build",
    "dev": "vite",
    "start": "npm run website:start",
    "build": "npm run build:lib && npm run build:standalone",
    "build:lib": "tsc -b && vite build --mode lib && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && node scripts/strip-css-from-dts.mjs",
    "build:lib:watch": "vite build --mode lib --watch",
    "build:standalone": "vite build --config vite.standalone.config.ts",
    "build:demo": "vite build",
    "copy:website-standalone": "node ./scripts/copy-standalone-to-website.mjs",
    "prepare:website-assets": "npm run build:standalone && npm run copy:website-standalone",
    "lint": "npm run eslint:ci",
    "eslint": "eslint . --fix",
    "eslint:ci": "eslint .",
    "prettier": "prettier --write \"**/*.{json,yml,yaml,md,html,css,scss}\"",
    "prettier:ci": "prettier --check \"**/*.{json,yml,yaml,md,html,css,scss}\"",
    "format": "npm run prettier && npm run eslint",
    "format:check": "npm run prettier:ci && npm run eslint:ci",
    "preview": "vite preview",
    "preview:standalone": "vite preview --outDir dist-standalone",
    "website": "npm --prefix website run start",
    "website:start": "npm --prefix website run start",
    "website:build": "npm --prefix website run build",
    "website:serve": "npm --prefix website run serve",
    "test:e2e": "npx playwright test",
    "test:e2e:vite": "npx playwright test --project=vite",
    "test:e2e:docusaurus": "npx playwright test --project=docusaurus",
    "test:e2e:ui": "npx playwright test --ui",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "is-ci || husky"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "@open-resource-discovery/specification": "1.16.3",
    "@open-resource-discovery/ui-components": "0.1.5",
    "@radix-ui/react-accordion": "1.2.16",
    "@radix-ui/react-collapsible": "1.1.16",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-select": "2.3.3",
    "@radix-ui/react-separator": "1.1.11",
    "@radix-ui/react-switch": "1.3.3",
    "@radix-ui/react-tabs": "1.1.17",
    "@radix-ui/react-tooltip": "1.2.12",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "highlight.js": "11.11.1",
    "jsonc-parser": "3.3.1",
    "lucide-react": "1.24.0",
    "playwright": "1.62.0",
    "react-markdown": "10.1.0",
    "react-resizable-panels": "4.12.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "uuid": "14.0.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml,md,html,css,scss}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@resvg/resvg-js": "2.6.2",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "25.9.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "jsdom": "29.1.1",
    "lint-staged": "17.2.0",
    "postcss": "8.5.16",
    "prettier": "3.9.5",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "7.18.1",
    "satori": "0.29.0",
    "tailwindcss": "4.3.2",
    "tsc-alias": "1.9.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
