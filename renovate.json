{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":pinAllExceptPeerDependencies"],
  "semanticCommits": "enabled",
  "enabledManagers": ["npm", "github-actions"],
  "branchPrefix": "deps/",
  "timezone": "Europe/Berlin",
  "schedule": ["every weekend"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "vulnerabilityAlerts": {
    "schedule": [],
    "automerge": false,
    "groupName": null
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "groupName": "all patches"
    },
    {
      "matchUpdateTypes": ["minor"],
      "groupName": "all minor updates"
    },
    {
      "groupName": "Radix UI",
      "matchManagers": ["npm"],
      "matchPackageNames": ["/^@radix-ui\\//"],
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "groupName": "Vite Build Tools",
      "matchManagers": ["npm"],
      "matchPackageNames": ["vite", "@vitejs/plugin-react", "vite-plugin-dts", "@tailwindcss/vite"],
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "groupName": "Tailwind CSS",
      "matchManagers": ["npm"],
      "matchPackageNames": ["tailwindcss", "@tailwindcss/typography", "tailwind-merge"],
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "groupName": "Linting Tools",
      "matchManagers": ["npm"],
      "matchPackageNames": ["eslint", "@eslint/js", "/^eslint-plugin/", "typescript-eslint", "prettier"],
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "groupName": "TypeScript",
      "matchManagers": ["npm"],
      "matchPackageNames": ["typescript", "@types/node", "@types/react", "@types/react-dom"],
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "groupName": "Testing",
      "matchManagers": ["npm"],
      "matchPackageNames": ["vitest", "jsdom", "@playwright/test"],
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "groupName": "Docusaurus",
      "matchManagers": ["npm"],
      "matchPackageNames": ["/^@docusaurus\\//", "@mdx-js/react", "docusaurus-plugin-sass"],
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "groupName": "Monaco Editor",
      "matchManagers": ["npm"],
      "matchPackageNames": ["@monaco-editor/react"],
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "groupName": "UI Utilities",
      "matchManagers": ["npm"],
      "matchPackageNames": ["class-variance-authority", "clsx", "lucide-react", "sonner"],
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "groupName": "GitHub Actions",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major", "minor", "patch", "digest"],
      "semanticCommitType": "chore",
      "automerge": true
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies", "devDependencies"],
      "matchDatasources": ["npm"],
      "matchUpdateTypes": ["patch", "minor"],
      "semanticCommitType": "chore",
      "automerge": true
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies", "devDependencies"],
      "matchDatasources": ["npm"],
      "matchUpdateTypes": ["major"],
      "semanticCommitType": "chore",
      "automerge": false
    }
  ]
}
